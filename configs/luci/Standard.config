CONFIG_GRUB_TITLE="HiH"
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=2048
# CONFIG_GRUB_CONSOLE is not set

CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y

CONFIG_PACKAGE_firewall4=y

CONFIG_PACKAGE_mentohust=y

